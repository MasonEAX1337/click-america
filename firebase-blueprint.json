{
  "entities": {
    "User": {
      "title": "User",
      "description": "A player in the game",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "state": { "type": "string", "description": "The user's selected US state" },
        "totalClicks": { "type": "number", "description": "Total clicks generated by the user" },
        "clicksPerSecond": { "type": "number", "description": "Passive clicks per second" },
        "clickPower": { "type": "number", "description": "Clicks generated per manual click" },
        "lastActive": { "type": "timestamp", "description": "When the user was last active" },
        "createdAt": { "type": "timestamp", "description": "When the user account was created" }
      },
      "required": ["uid", "displayName", "state", "totalClicks", "clicksPerSecond", "clickPower", "lastActive", "createdAt"]
    },
    "State": {
      "title": "State",
      "description": "A US state's collective stats",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The state's name" },
        "totalClicks": { "type": "number", "description": "Total clicks generated by all users in this state" }
      },
      "required": ["name", "totalClicks"]
    },
    "GlobalStats": {
      "title": "GlobalStats",
      "description": "Global game statistics",
      "type": "object",
      "properties": {
        "totalClicks": { "type": "number", "description": "Total clicks generated globally" },
        "currentEvent": { "type": "string", "description": "The currently active global event" }
      },
      "required": ["totalClicks"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A live activity feed event",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user who triggered the event" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "state": { "type": "string", "description": "The user's state" },
        "message": { "type": "string", "description": "The activity message" },
        "timestamp": { "type": "timestamp", "description": "When the activity occurred" }
      },
      "required": ["userId", "displayName", "state", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and stats"
    },
    "/states/{stateId}": {
      "schema": { "$ref": "#/entities/State" },
      "description": "Stores collective stats for each US state"
    },
    "/global/stats": {
      "schema": { "$ref": "#/entities/GlobalStats" },
      "description": "Stores global game statistics"
    },
    "/activity/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Stores recent activity events for the live feed"
    }
  }
}
